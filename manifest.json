{
    "name": "Compress",
    "short_name": "Compress",
    "description": "Compress videos on your device. No uploads, no servers.",
    "start_url": "/",
    "display": "standalone",
    "orientation": "any",
    "background_color": "#FAF8F5",
    "theme_color": "#FAF8F5",
    "icons": [
        {
            "src": "icon-192.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "any"
        },
        {
            "src": "icon-512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "any"
        },
        {
            "src": "icon-maskable-192.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "maskable"
        },
        {
            "src": "icon-maskable-512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "maskable"
        }
    ],
    "categories": ["utilities", "productivity"],
    "screenshots": [
        {
            "src": "screenshot.png",
            "sizes": "780x1688",
            "type": "image/png",
            "form_factor": "narrow",
            "label": "Compress a video on your phone"
        }
    ],
    "share_target": {
        "action": "/",
        "method": "POST",
        "enctype": "multipart/form-data",
        "params": {
            "title": "title",
            "text": "text",
            "url": "url",
            "files": [
                {
                    "name": "media",
                    "accept": ["video/*", "image/*"]
                }
            ]
        }
    }
}
